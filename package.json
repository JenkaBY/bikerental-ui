{
  "name": "bikerental-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:coverage": "ng test --configuration=ci",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,css}\"",
    "fix": "npm run lint:fix && npm run format",
    "analyze": "ng build --stats-json && webpack-bundle-analyzer dist/bikerental-ui/browser/stats.json",
    "prepare": "husky",
    "i18n:extract": "ng extract-i18n --output-path src/locale",
    "generate:api": "ng-openapi -c src/config/openapi.config.ts"
  },
  "lint-staged": {
    "src/**/*.{ts,html}": [
      "eslint --fix"
    ],
    "src/**/*.{ts,html,scss,css,json}": [
      "prettier --write"
    ]
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/material": "^21.2.7",
    "@angular/platform-browser": "^21.2.9",
    "@angular/router": "^21.2.9",
    "html5-qrcode": "^2.3.8",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@angular/localize": "^21.2.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@vitest/coverage-v8": "^4.1.4",
    "angular-eslint": "21.3.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "ng-openapi": "^0.2.18",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.0",
    "typescript-eslint": "8.58.2",
    "vitest": "^4.1.4",
    "webpack-bundle-analyzer": "^5.3.0"
  }
}
