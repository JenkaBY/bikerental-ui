{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm test)",
      "Bash(npm run test:watch)",
      "Bash(npm run test:coverage)",
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run fix)",
      "Bash(npm run build)",
      "Bash(npm run build:all)"
    ],
    "deny": [
      "Read(./memory-bank/**)",
      "Read(./.github/copilot-instructions.md)",
      "Read(./.github/instructions/**)",
      "Read(./.github/prompts/**)",
      "Read(./.github/agents/**)",
      "Read(./.cursor/**)"
    ]
  }
}
